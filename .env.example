# Make a copy of this to set environment variables for local development
# cp .env.example .env

# Databricks auth
DATABRICKS_CONFIG_PROFILE=DEFAULT
# DATABRICKS_HOST=https://fevm-sean-zhang.cloud.databricks.com
# DATABRICKS_TOKEN=dapi....

# LLM model endpoint (Claude Sonnet 4.6 or Opus 4.6)
LLM_ENDPOINT_NAME=databricks-claude-sonnet-4-6

# MLflow experiment
MLFLOW_EXPERIMENT_ID=

# Lakebase Autoscaling for short-term + long-term memory
# Option 1 (preferred): Autoscaling endpoint name
# LAKEBASE_AUTOSCALING_ENDPOINT=
# Option 2: Project + branch
# LAKEBASE_AUTOSCALING_PROJECT=
# LAKEBASE_AUTOSCALING_BRANCH=

# Embedding endpoint for long-term memory vector search
DATABRICKS_EMBEDDING_ENDPOINT=databricks-gte-large-en

# ZINC Vector Search index for chemical similarity
ZINC_VS_INDEX=sean_zhang_catalog.gsk_india_hls.zinc_vs

# Server config
TASK_TIMEOUT_SECONDS=3600
POLL_INTERVAL_SECONDS=1
CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300
MLFLOW_TRACKING_URI="databricks"
MLFLOW_REGISTRY_URI="databricks-uc"
